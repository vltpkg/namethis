{
  "name": "namethis",
  "version": "1.0.1",
  "description": "Check the existence of a npmjs.com package",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "namethis": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "node --import tsx --test test/index.ts",
    "release": "bash scripts/release.sh",
    "prepublishOnly": "vlt run build"
  },
  "author": {
    "name": "Darcy Clarke",
    "email": "darcy@darcyclarke.me"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vltpkg/namethis.git"
  },
  "bugs": [
    {
      "type": "link",
      "url": "https://github.com/vltpkg/namethis/issues"
    },
    {
      "type": "link",
      "url": "https://github.com/vltpkg/namethis/issues"
    }
  ],
  "homepage": "https://github.com/vltpkg/namethis#readme",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "package",
    "exists",
    "existence",
    "publish",
    "visibility",
    "private",
    "public",
    "npm",
    "registry"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
